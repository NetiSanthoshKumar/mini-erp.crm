# PostgreSQL connection string
# Local:    postgresql://postgres:postgres@localhost:5432/mini_erp_crm
# Supabase/Neon/Render: copy the connection string they give you
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mini_erp_crm"

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET="change-this-to-a-long-random-string"

PORT=4000

# Comma-separated list of allowed frontend origins
CORS_ORIGIN="http://localhost:5173"
